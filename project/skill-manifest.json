      "required_inputs": [".pm/competitors/", ".pm/product/inventory.md"],
      "outputs": [".pm/gaps/[date]-analysis.md"],
      "quality_gates": [
        {"metric": "evidence_required", "condition": "== true", "severity": "HARD"},
        {"metric": "winning_score", "condition": ">= 25", "severity": "WARN"}
      ],
      "next_skills_if_pass": ["pm:prd-generator"],
      "next_skills_if_fail": ["pm:research-agent"],
      "phase": 3
    },
    "pm:prd-generator": {
      "domain": "pm",
