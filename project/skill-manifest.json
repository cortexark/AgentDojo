    "pm:research-agent": {
      "domain": "pm",
      "name": "Research Agent",
      "description": "Deep competitor research and profiling: features, pricing, sentiment",
      "required_inputs": [],
      "outputs": [".pm/competitors/[company].md"],
      "quality_gates": [
        {"metric": "competitor_count", "condition": ">= 3", "severity": "WARN"}
      ],
      "next_skills_if_pass": ["pm:gap-analyst"],
      "next_skills_if_fail": [],
      "phase": 1
    },
    "pm:gap-analyst": {
      "domain": "pm",
